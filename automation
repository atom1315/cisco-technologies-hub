### Playbook: проверка соответствия (Compliance Check)

   yaml

# playbooks/compliance_check.yml
- name: Network Compliance Check
  hosts: all
  gather_facts: no

  vars:
    required_config_lines:
      - "service timestamps log datetime msec"
      - "service password-encryption"
      - "no ip http server"
      - "ip ssh version 2"
      - "banner motd"
      - "ntp server"
      - "logging buffered"

  tasks:
    - name: Get running config
      cisco.ios.ios_command:
        commands:
          - show running-config
      register: running_config

    - name: Check required configurations
      set_fact:
        compliance_results: >-
          {{ compliance_results | default([]) + [{
            'check': item,
            'status': 'PASS' if item in running_config.stdout[0] else 'FAIL'
          }] }}
      loop: "{{ required_config_lines }}"

    - name: Display compliance report
      debug:
        msg: |
          === Compliance Report: {{ inventory_hostname }} ===
          {% for result in compliance_results %}
          {{ '' if result.status == 'PASS' else '' }} {{ result.check }}: {{ result.status }}
          {% endfor %}

    - name: Fail if non-compliant
      fail:
        msg: "{{ inventory_hostname }} is NOT compliant!"
      when: compliance_results | selectattr('status', 'equalto', 'FAIL') | list | length > 0
      ignore_errors: yes




## Terraform для Cisco

### Простыми словами

Terraform управляет инфраструктурой декларативно: вы описываете, что должно быть, а Terraform сам определяет, какие изменения нужно внести. В отличие от Ansible, Terraform хранит состояние (state file) и может точно показать, что изменилось (plan), перед применением.

### Пример: управление Cisco ACI через Terraform

   hcl
# main.tf — управление Cisco ACI

terraform {
  required_providers {
    aci = {
      source  = "CiscoDevNet/aci"
      version = "~> 2.0"
    }
  }
}

provider "aci" {
  username = var.aci_username
  password = var.aci_password
  url      = var.aci_url
  insecure = true
}

# Создать Tenant
resource "aci_tenant" "production" {
  name        = "PROD"
  description = "Production tenant managed by Terraform"
}

# Создать VRF
resource "aci_vrf" "prod_vrf" {
  tenant_dn = aci_tenant.production.id
  name      = "PROD_VRF"
}

# Создать Bridge Domain
resource "aci_bridge_domain" "web_bd" {
  tenant_dn          = aci_tenant.production.id
  name               = "WEB_BD"
  relation_fv_rs_ctx = aci_vrf.prod_vrf.id
}

# Создать Subnet
resource "aci_subnet" "web_subnet" {
  parent_dn = aci_bridge_domain.web_bd.id
  ip        = "10.1.1.1/24"
  scope     = ["public"]
}

# Создать Application Profile
resource "aci_application_profile" "web_app" {
  tenant_dn = aci_tenant.production.id
  name      = "WEB_APP"
}

# Создать EPG
resource "aci_application_epg" "web_epg" {
  application_profile_dn = aci_application_profile.web_app.id
  name                   = "WEB_EPG"
  relation_fv_rs_bd      = aci_bridge_domain.web_bd.id
}

# Создать контракт (фильтрация трафика)
resource "aci_contract" "web_contract" {
  tenant_dn = aci_tenant.production.id
  name      = "ALLOW_HTTPS"
}

resource "aci_contract_subject" "https_subject" {
  contract_dn = aci_contract.web_contract.id
  name        = "HTTPS"
}

# Переменные
variable "aci_username" { default = "admin" }
variable "aci_password" { sensitive = true }
variable "aci_url" { default = "https://apic.example.com" }

# Outputs
output "tenant_id" {
  value = aci_tenant.production.id
}


   bash
# Рабочий процесс Terraform
terraform init      # Установить провайдер
terraform plan      # Показать план изменений
terraform apply     # Применить
terraform destroy   # Удалить всё (осторожно!)




## pyATS — тестирование сети

### Простыми словами

pyATS (Python Automated Test System) — это фреймворк от Cisco для автоматического тестирования сетей. Genie — библиотека поверх pyATS, которая умеет парсить вывод CLI-команд в структурированные данные. Это как unit-тесты, только для сети: «проверь, что все OSPF-соседства в состоянии FULL», «проверь, что BGP получает нужное количество префиксов».

### Пример: тестирование до и после изменений

   python
# pyats_test.py — snapshot и сравнение состояния сети
from genie.testbed import load
from genie.utils.diff import Diff

# Загрузить testbed (список устройств)
testbed = load("testbed.yml")

device = testbed.devices["R1"]
device.connect(log_stdout=False)

# Snapshot ДО изменений 

print(" Сохраняем snapshot ДО изменений...\n")

ospf_before = device.learn("ospf")
bgp_before = device.learn("bgp")
interfaces_before = device.learn("interface")
routes_before = device.learn("routing")

#  Здесь происходят изменения в сети ...
input("🔧 Внесите изменения в сеть и нажмите Enter...")

#  Snapshot ПОСЛЕ изменений 

print(" Сохраняем snapshot ПОСЛЕ изменений...\n")

ospf_after = device.learn("ospf")
bgp_after = device.learn("bgp")
interfaces_after = device.learn("interface")
routes_after = device.learn("routing")

#  Сравнение 

print("=== OSPF Diff ===")
ospf_diff = Diff(ospf_before.info, ospf_after.info)
ospf_diff.findDiff()
print(ospf_diff)

print("\n=== BGP Diff ===")
bgp_diff = Diff(bgp_before.info, bgp_after.info)
bgp_diff.findDiff()
print(bgp_diff)

print("\n=== Routes Diff ===")
routes_diff = Diff(routes_before.info, routes_after.info)
routes_diff.findDiff()
print(routes_diff)

device.disconnect()


