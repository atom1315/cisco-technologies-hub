### Playbook: бэкап всех устройств

   yaml

# playbooks/backup.yml
- name: Backup all Cisco devices
  hosts: all
  gather_facts: no

  tasks:
    - name: Get current date
      set_fact:
        backup_date: "{{ lookup('pipe', 'date +%Y-%m-%d_%H-%M') }}"
      run_once: true

    - name: Backup running config
      cisco.ios.ios_config:
        backup: yes
        backup_options:
          dir_path: "./backups/{{ backup_date }}"
          filename: "{{ inventory_hostname }}.cfg"

    - name: Display backup status
      debug:
        msg: " Backup saved: ./backups/{{ backup_date }}/{{ inventory_hostname }}.cfg"


### Playbook: раскатка VLAN с шаблонами

   yaml

# playbooks/deploy_vlans.yml
- name: Deploy VLANs to all switches
  hosts: switches
  gather_facts: no

  vars:
    vlans:
      - id: 10
        name: ACCOUNTING
        subnet: 192.168.10.0/24
      - id: 20
        name: DEVELOPERS
        subnet: 192.168.20.0/24
      - id: 30
        name: MANAGEMENT
        subnet: 192.168.30.0/24
      - id: 99
        name: NATIVE
      - id: 100
        name: GUEST

  tasks:
    - name: Create VLANs
      cisco.ios.ios_vlans:
        config:
          - vlan_id: "{{ item.id }}"
            name: "{{ item.name }}"
            state: active
        state: merged
      loop: "{{ vlans }}"

    - name: Configure trunk ports
      cisco.ios.ios_config:
        lines:
          - switchport trunk encapsulation dot1q
          - switchport mode trunk
          - switchport trunk native vlan 99
          - switchport trunk allowed vlan 10,20,30,99,100
        parents: "interface {{ item }}"
      loop: "{{ trunk_ports | default(['GigabitEthernet0/24']) }}"

    - name: Verify VLANs
      cisco.ios.ios_command:
        commands:
          - show vlan brief
      register: vlan_output

    - name: Show VLANs
      debug:
        msg: "{{ vlan_output.stdout_lines[0] }}"


