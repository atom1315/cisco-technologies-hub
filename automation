# Автоматизация и программируемость — Подробное руководство

## Зачем автоматизировать сеть

Ручная настройка 5 устройств — это нормально. Ручная настройка 500 — это ад. 
Человек делает ошибки, забывает сохранить конфигурацию, путает интерфейсы. Автоматизация решает эти проблемы: конфигурация описывается как код, тестируется, 
хранится в Git и применяется одинаково на все устройства. Если что-то пошло не так — откат к предыдущей версии за секунды.



## NETCONF и RESTCONF

### Простыми словами

NETCONF и RESTCONF — это протоколы для программного управления устройствами. Вместо того чтобы подключаться по SSH и вводить команды как человек, 
ваш скрипт отправляет структурированные запросы (XML или JSON) и получает структурированные ответы. Это надёжнее, чем парсить текстовый вывод CLI.

- **NETCONF** — работает по SSH (порт 830), использует XML и YANG-модели. Поддерживает транзакции: либо все изменения применяются, либо ничего.
- **RESTCONF** — HTTP-версия NETCONF. Работает через REST API (GET, POST, PUT, DELETE) с JSON/XML. 
Проще в использовании, отлично подходит для интеграции с веб-приложениями.

### На каком оборудовании

- IOS XE: Catalyst 9000, ISR 4000, ASR 1000, CSR 1000v
- NX-OS: Nexus 9000 серия
- IOS XR: ASR 9000, NCS серия

### Включение NETCONF и RESTCONF на IOS XE


! Включить NETCONF 

netconf-yang
netconf-yang feature candidate-datastore

! Включить RESTCONF 

restconf
ip http server
ip http secure-server
ip http authentication local

! Проверка

show netconf-yang sessions           ! Активные NETCONF-сессии
show platform software yang-management process  ! Статус процессов

### Python: работа с NETCONF через ncclient

   python
from ncclient import manager
import xmltodict

# Подключение к устройству
device = manager.connect(
    host="192.168.1.1",
    port=830,
    username="admin",
    password="cisco123",
    hostkey_verify=False,
    device_params={"name": "iosxe"},
)

# Получить текущие интерфейсы 

filter_interfaces = """
<filter>
  <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces"/>
</filter>
"""

result = device.get(filter_interfaces)
data = xmltodict.parse(result.xml)

interfaces = data["rpc-reply"]["data"]["interfaces"]["interface"]
if not isinstance(interfaces, list):
    interfaces = [interfaces]

print("=== Интерфейсы ===\n")
for intf in interfaces:
    name = intf["name"]
    enabled = intf.get("enabled", "N/A")
    print(f"  {name}: enabled={enabled}")

# Изменить описание интерфейса 

config_xml = """
<config>
  <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
    <interface>
      <name>GigabitEthernet2</name>
      <description>Configured via NETCONF</description>
    </interface>
  </interfaces>
</config>
"""

result = device.edit_config(target="running", config=config_xml)
print(f"\nEdit result: {result.ok}")

# Сохранить конфигурацию 

save_rpc = """
<save-config xmlns="http://cisco.com/yang/cisco-ia"/>
"""
device.dispatch(xmltodict.parse(save_rpc))

device.close_session()


### Python: работа с RESTCONF через requests

   python
import requests
import json

host = "192.168.1.1"
base_url = f"https://{host}/restconf"
headers = {
    "Accept": "application/yang-data+json",
    "Content-Type": "application/yang-data+json",
}
auth = ("admin", "cisco123")

# GET: получить все интерфейсы 

url = f"{base_url}/data/ietf-interfaces:interfaces"
response = requests.get(url, headers=headers, auth=auth, verify=False)

interfaces = response.json()["ietf-interfaces:interfaces"]["interface"]
print("=== Интерфейсы (RESTCONF) ===\n")
for intf in interfaces:
    print(f"  {intf['name']}: {intf.get('description', 'no description')}")
    if "ietf-ip:ipv4" in intf:
        for addr in intf["ietf-ip:ipv4"].get("address", []):
            print(f"    IP: {addr['ip']}/{addr['netmask']}")

# PUT: настроить Loopback 

loopback_url = f"{base_url}/data/ietf-interfaces:interfaces/interface=Loopback100"
loopback_data = {
    "ietf-interfaces:interface": {
        "name": "Loopback100",
        "description": "Created via RESTCONF",
        "type": "iana-if-type:softwareLoopback",
        "enabled": True,
        "ietf-ip:ipv4": {
            "address": [{"ip": "10.100.100.1", "netmask": "255.255.255.255"}]
        },
    }
}

response = requests.put(
    loopback_url,
    headers=headers,
    auth=auth,
    data=json.dumps(loopback_data),
    verify=False,
)
print(f"\nLoopback100 создан: {response.status_code}")

