# Коммутация (Switching) — Подробное руководство


## Что такое коммутация

Коммутация — это передача данных внутри одной локальной сети на втором уровне модели OSI (канальный уровень).
Коммутатор (switch) получает кадр (frame), смотрит на MAC-адрес назначения и отправляет его только в нужный порт, а не во все порты. 
Это базовый «кирпичик» любой сети — без коммутаторов компьютеры в офисе просто не смогут общаться.

## VLAN (Virtual LAN)

### Простыми словами

VLAN — это способ разделить один физический коммутатор на несколько «виртуальных» сетей.
Компьютеры в одном VLAN видят друг друга, но не видят устройства в другом VLAN, даже если они подключены к одному и тому же коммутатору.
Это как перегородки в офисе — все в одном здании, но каждый отдел в своей комнате.

### Где применяется

- Любой офис: отделить бухгалтерию от разработчиков, гостевой Wi-Fi от корпоративного
- Дата-центры: изоляция серверных сегментов
- Провайдеры: разделение трафика клиентов
- Производство: отделение IoT/OT-устройств от корпоративной сети

### На каком оборудовании

- L2-коммутаторы: Catalyst 9200, 2960-X/L, 3560
- L3-коммутаторы: Catalyst 9300/9500 (маршрутизация между VLAN)
- ЦОД: Nexus 3000/5000/7000/9000

### Основные команды CLI

!  Создание VLAN 

vlan 10
 name ACCOUNTING
vlan 20
 name DEVELOPERS
vlan 30
 name MANAGEMENT
vlan 99
 name NATIVE_VLAN
vlan 100
 name GUEST_WIFI

! Назначение порта в VLAN (Access) 

interface GigabitEthernet0/1
 description PC_Buhgalteriya
 switchport mode access
 switchport access vlan 10
 switchport nonegotiate
 spanning-tree portfast

! Транковый порт (Trunk) 

! Trunk — порт, который передаёт трафик нескольких VLAN между коммутаторами
interface GigabitEthernet0/24
 description TRUNK_TO_SW2
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 99
 switchport trunk allowed vlan 10,20,30,99
 switchport nonegotiate

!  Маршрутизация между VLAN (Router-on-a-Stick) 

! На маршрутизаторе — субинтерфейсы
interface GigabitEthernet0/0.10
 encapsulation dot1Q 10
 ip address 192.168.10.1 255.255.255.0

interface GigabitEthernet0/0.20
 encapsulation dot1Q 20
 ip address 192.168.20.1 255.255.255.0

!  Маршрутизация между VLAN (SVI на L3-коммутаторе) 

! Более производительный вариант — прямо на коммутаторе
ip routing

interface Vlan10
 ip address 192.168.10.1 255.255.255.0
 no shutdown

interface Vlan20
 ip address 192.168.20.1 255.255.255.0
 no shutdown

!  Безопасность портов 

interface GigabitEthernet0/1
 switchport port-security
 switchport port-security maximum 2
 switchport port-security violation restrict
 switchport port-security mac-address sticky

!  Диагностика 

show vlan brief                     ! Все VLAN и их порты
show interfaces trunk               ! Транковые порты
show interfaces GigabitEthernet0/1 switchport  ! Детали порта
show mac address-table              ! Таблица MAC-адресов
show mac address-table vlan 10      ! MAC-адреса в конкретном VLAN


### Python-скрипт: массовое создание VLAN на нескольких коммутаторах

   python
from netmiko import ConnectHandler

switches = [
    {"device_type": "cisco_ios", "host": "192.168.1.10",
     "username": "admin", "password": "cisco123"},
    {"device_type": "cisco_ios", "host": "192.168.1.11",
     "username": "admin", "password": "cisco123"},
    {"device_type": "cisco_ios", "host": "192.168.1.12",
     "username": "admin", "password": "cisco123"},
]

vlans = [
    {"id": "10", "name": "ACCOUNTING"},
    {"id": "20", "name": "DEVELOPERS"},
    {"id": "30", "name": "MANAGEMENT"},
    {"id": "99", "name": "NATIVE_VLAN"},
    {"id": "100", "name": "GUEST_WIFI"},
]

for switch in switches:
    try:
        conn = ConnectHandler(**switch)
        hostname = conn.find_prompt().replace("#", "")
        print(f"\n[{hostname}] Подключено к {switch['host']}")

        for vlan in vlans:
            commands = [
                f"vlan {vlan['id']}",
                f" name {vlan['name']}",
            ]
            conn.send_config_set(commands)
            print(f"   VLAN {vlan['id']} ({vlan['name']}) создан")

        conn.save_config()
        print(f"   Конфигурация сохранена")
        conn.disconnect()

    except Exception as e:
        print(f"   Ошибка: {switch['host']} — {e}")
```

